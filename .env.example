# Database (MySQL). Example for PlanetScale / local MySQL.
DATABASE_URL="mysql://user:password@localhost:3306/church_stack"

# next-auth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# /dev console — comma-separated emails (no DB column).
# If empty, set ALLOW_DEV_CONSOLE=true for local signed-in access.
PLATFORM_DEV_EMAILS="admin@churchstack.example,jordan.vera96@gmail.com"
ALLOW_DEV_CONSOLE="true"

# Shared API URL used by apps/church-site (and Vercel env injection).
PLATFORM_API_URL="http://localhost:3000/api/trpc"

# Optional local church-site preview base (opened from /dev).
NEXT_PUBLIC_CHURCH_SITE_PREVIEW_URL="http://localhost:3001"

# Support email shown in church signup (Planning Center import help, etc.).
NEXT_PUBLIC_SUPPORT_EMAIL="hello@churchstack.com"

# Vercel automation (website provision from /dev)
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_GIT_REPO=owner/church-stack
# VERCEL_GIT_REF=main
# VERCEL_CHURCH_SITE_ROOT=apps/church-site

# EAS / Expo automation (white-label builds from /dev)
# EXPO_TOKEN=
# EAS_PROJECT_ID=

# Stripe billing (Site / Growth / Custom subscriptions)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRICE_SITE=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_CUSTOM=price_...
