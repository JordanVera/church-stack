// Church Stack — multi-tenant Prisma schema.
// Every domain row is keyed by `churchId` (the tenant). A `Church` row also
// carries the whitelabel branding used by the native app at runtime.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  LEADER
  MEMBER
}

enum WebsiteStatus {
  NONE
  PENDING
  DEPLOYING
  LIVE
  FAILED
}

enum MobilePlan {
  SHARED
  WHITELABEL
}

enum MobileBuildStatus {
  NONE
  QUEUED
  BUILDING
  SUBMITTED
  LIVE
  FAILED
}

// Tenant + its whitelabel branding.
model Church {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  tagline        String?
  logoUrl        String?
  primaryColor   String   @default("#1a8bbd")
  secondaryColor String   @default("#84dccf")
  contactEmail   String?
  phone          String?
  address        String?
  timezone       String   @default("America/Chicago")
  isActive       Boolean  @default(true)

  // Public social links (optional)
  facebookUrl  String?
  instagramUrl String?
  youtubeUrl   String?
  threadsUrl   String?

  // Feature flags (whitelabel toggles per church)
  givingEnabled   Boolean @default(true)
  eventsEnabled   Boolean @default(true)
  sermonsEnabled  Boolean @default(true)

  // Website provisioning (per-church Next.js / Vercel project)
  websiteStatus       WebsiteStatus @default(NONE)
  websiteUrl          String?
  customDomain        String?
  vercelProjectId     String?
  vercelDeploymentId  String?

  // Mobile: shared App Store app by default; white-label EAS for paid tier
  mobilePlan         MobilePlan        @default(SHARED)
  mobileBuildStatus  MobileBuildStatus @default(NONE)

  // Optional Planning Center Personal Access Token credentials
  planningCenterApiKey    String? @db.Text
  planningCenterSecretKey String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  announcements Announcement[]
  events        Event[]
  sermonSeries  SermonSeries[]
  pastors       Pastor[]
  locations     Location[]
  adminEmails   ChurchAdminEmail[]

  @@index([slug])
}

/// Admin contact emails for a church (church-wide when locationId is null).
model ChurchAdminEmail {
  id         String   @id @default(cuid())
  churchId   String
  email      String
  /// When set, this admin is associated with a specific campus/location.
  locationId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  church   Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([locationId])
  @@index([email])
}

// Church leadership (display / campus association — not app Users).
model Pastor {
  id        String   @id @default(cuid())
  churchId  String
  firstName String
  lastName  String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church    Church     @relation(fields: [churchId], references: [id], onDelete: Cascade)
  locations Location[]

  @@index([churchId])
}

// Campus / site (e.g. Grace Church North).
model Location {
  id        String  @id @default(cuid())
  churchId  String
  name      String
  address   String
  pastorId  String?
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church      Church             @relation(fields: [churchId], references: [id], onDelete: Cascade)
  pastor      Pastor?            @relation(fields: [pastorId], references: [id], onDelete: SetNull)
  services    Service[]
  adminEmails ChurchAdminEmail[]

  @@index([churchId])
  @@index([pastorId])
}

// Recurring weekly service at a location.
model Service {
  id         String   @id @default(cuid())
  locationId String
  name       String
  /// 0 = Sunday … 6 = Saturday (JS Date.getDay())
  dayOfWeek  Int
  /// Local start time as HH:mm (24h)
  startTime  String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

// Global user (can belong to multiple churches via Membership).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  /// Platform admin (Church Stack /admin). Independent of per-church MembershipRole.
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

// Join table: which user belongs to which church, and with what role.
model Membership {
  id       String         @id @default(cuid())
  userId   String
  churchId String
  role     MembershipRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([userId, churchId])
  @@index([userId])
  @@index([churchId])
}

// --- next-auth models ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Church-scoped content ---

model Announcement {
  id        String   @id @default(cuid())
  churchId  String
  title     String
  body      String   @db.Text
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
}

model Event {
  id          String   @id @default(cuid())
  churchId    String
  title       String
  description String?  @db.Text
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([startsAt])
}

model SermonSeries {
  id          String   @id @default(cuid())
  churchId    String
  title       String
  description String?  @db.Text
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
}
