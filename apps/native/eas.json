{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "shared": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://churchstack.example"
      }
    },
    "whitelabel": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://churchstack.example"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    }
  },
  "submit": {
    "shared": {},
    "whitelabel": {}
  }
}
